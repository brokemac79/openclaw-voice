PORT=8787

# Required by /api/voice/turn (browser must send this token).
VOICE_API_BEARER_TOKEN=replace-with-a-long-random-token

# Full HTTP(S) URL for the upstream OpenClaw-compatible chat endpoint; do not use ws:// or wss:// here.
OPENCLAW_URL=http://127.0.0.1:3000/api/chat

# Optional OpenClaw endpoint settings.
OPENCLAW_METHOD=POST
OPENCLAW_INPUT_FIELD=input
OPENCLAW_OUTPUT_FIELD=response
OPENCLAW_AUTH_BEARER=replace-with-upstream-token-if-needed

# Local faster-whisper transcription settings.
FASTER_WHISPER_PYTHON_BIN=python3
FASTER_WHISPER_MODEL=base.en
FASTER_WHISPER_LANGUAGE=en
FASTER_WHISPER_DEVICE=auto
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_TIMEOUT_MS=120000

# Optional Edge TTS tuning.
EDGE_TTS_VOICE=en-US-AndrewNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
EDGE_TTS_PITCH=+0Hz

# TTS provider settings.
# edge: always use Microsoft Edge TTS
# piper: always use local Piper CLI model
# auto: try Edge first then Piper
TTS_PROVIDER=edge
# Piper fallback currently applies when TTS_PROVIDER=edge.
TTS_FALLBACK_PROVIDER=piper

# Local Piper TTS configuration.
# Required when Piper is used directly or as a fallback.
PIPER_BIN=piper
PIPER_MODEL_PATH=/absolute/path/to/en_US-lessac-medium.onnx
PIPER_SPEAKER_ID=
PIPER_LENGTH_SCALE=
PIPER_NOISE_SCALE=
PIPER_NOISE_W=
PIPER_SENTENCE_SILENCE=

# Optional Sonos local relay settings. Leave all blank if you do not use Sonos.
SONOS_RELAY_URL=
# Alias for the primary LAN/Pi relay. If SONOS_RELAY_URL is also set, that value wins.
SONOS_RELAY_PI_URL=
# Secondary relay used when the primary relay fails or is being migrated.
SONOS_RELAY_FALLBACK_URL=
SONOS_RELAY_AUTH_BEARER=
# Timeout per relay attempt before trying the fallback URL.
SONOS_RELAY_TIMEOUT_MS=12000
SONOS_ROOM_DEFAULT=Kitchen

# Optional desktop client defaults.
VOICE_CLIENT_SERVICE_URL=http://127.0.0.1:8787
VOICE_CLIENT_API_PATH=/api/voice/turn
VOICE_CLIENT_BEARER_TOKEN=replace-with-your-voice-token
VOICE_CLIENT_SESSION_ID=OfficeDesk
VOICE_CLIENT_SONOS_ROOM=Office
VOICE_CLIENT_OUTPUT_DIR=/tmp/openclaw-voice-client
# {output} is replaced with a generated file path.
VOICE_CLIENT_RECORD_COMMAND=sox -q -d -c 1 -r 16000 "{output}" trim 0 5
# Local playback of reply audio is optional. Uncomment and set for your OS.
# macOS: VOICE_CLIENT_PLAY_COMMAND=afplay "{output}"
# Linux: VOICE_CLIENT_PLAY_COMMAND=mpg123 "{output}"
# Windows: VOICE_CLIENT_PLAY_COMMAND=powershell -NoProfile -Command "Start-Process '{output}'"

# Phase 4 wake settings.
# `auto` tries wake word + hotkey and still allows manual Enter fallback.
VOICE_CLIENT_WAKE_MODE=auto
# Set true to add timed ambient captures without requiring strict ambient mode.
VOICE_CLIENT_AMBIENT_MODE=false
# Milliseconds between ambient captures when ambient mode is enabled.
VOICE_CLIENT_AMBIENT_INTERVAL_MS=20000
# Start the ambient loop immediately on launch.
VOICE_CLIENT_AMBIENT_AUTO_START=true
VOICE_CLIENT_WAKE_WORD_ENABLED=true
VOICE_CLIENT_HOTKEY_ENABLED=true
# Ignore repeated wake triggers for this long.
VOICE_CLIENT_WAKE_COOLDOWN_MS=2500
# Terminal bell always plays; set a command only if you want an extra custom sound.
VOICE_CLIENT_WAKE_BEEP_ENABLED=true
VOICE_CLIENT_WAKE_BEEP_COMMAND=

# Picovoice Porcupine wake-word configuration.
PORCUPINE_ACCESS_KEY=replace-with-picovoice-access-key
# Absolute path to your custom `Hey OpenClaw` (or other) `.ppn` file.
VOICE_CLIENT_PORCUPINE_KEYWORD_PATH=/absolute/path/to/Hey-OpenClaw.ppn
# Optional absolute path to a Porcupine model file.
VOICE_CLIENT_PORCUPINE_MODEL_PATH=/absolute/path/to/porcupine_params.pv
VOICE_CLIENT_PORCUPINE_SENSITIVITY=0.5
VOICE_CLIENT_PORCUPINE_DEVICE_INDEX=-1

# Global hotkey fallback (Linux X11 / macOS / Windows).
# Default combination is Ctrl+Shift+Space.
VOICE_CLIENT_HOTKEY_KEY=SPACE
VOICE_CLIENT_HOTKEY_MODIFIERS=CTRL+SHIFT
