PORT=8787

# Required by /api/voice/turn (browser must send this token).
VOICE_API_BEARER_TOKEN=

# Full HTTP(S) URL for the upstream OpenClaw-compatible chat endpoint; do not use ws:// or wss:// here.
OPENCLAW_URL=http://127.0.0.1:3000/api/chat

# Optional OpenClaw endpoint settings.
OPENCLAW_METHOD=POST
OPENCLAW_INPUT_FIELD=input
OPENCLAW_OUTPUT_FIELD=response
OPENCLAW_AUTH_BEARER=

# Local faster-whisper transcription settings.
FASTER_WHISPER_PYTHON_BIN=python3
FASTER_WHISPER_MODEL=base.en
FASTER_WHISPER_LANGUAGE=en
FASTER_WHISPER_DEVICE=auto
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_TIMEOUT_MS=120000

# Optional Edge TTS tuning.
EDGE_TTS_VOICE=en-US-AndrewNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
EDGE_TTS_PITCH=+0Hz

# Optional Sonos local relay settings.
# Example relay endpoint: http://127.0.0.1:5005/play-audio
SONOS_RELAY_URL=
SONOS_ROOM_DEFAULT=

# Optional desktop client defaults.
VOICE_CLIENT_SERVICE_URL=http://127.0.0.1:8787
VOICE_CLIENT_API_PATH=/api/voice/turn
VOICE_CLIENT_BEARER_TOKEN=
VOICE_CLIENT_SESSION_ID=Desktop
VOICE_CLIENT_SONOS_ROOM=
VOICE_CLIENT_OUTPUT_DIR=
# {output} is replaced with a generated file path.
VOICE_CLIENT_RECORD_COMMAND=sox -q -d -c 1 -r 16000 "{output}" trim 0 5
VOICE_CLIENT_PLAY_COMMAND=
